---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header class="site-header">
    <div class="header-inner">
      <a href="https://fightscience.com/">
        <img src="/images/site/logo.png" alt="FightScience" class="header-logo" />
      </a>
      <div class="header-contact">
        <div>Email: <a href="mailto:support@fightscience.com">support@fightscience.com</a></div>
        <div>Phone#: <a href="tel:18448288225">1-844-828-8225</a></div>
      </div>
    </div>
  </header>
  <main class="sales-page">
    <slot />
  </main>
  <footer class="site-footer">
    <div class="footer-inner">
      <p>Copyright 2026 FightScience.com</p>
      <p>
        <a href="https://fightscience.com/privacy-policy/">Privacy Policy</a> -
        <a href="https://fightscience.com/terms/">Terms of Use</a> -
        <a href="https://fightscience.com/contact/">Contact Us</a>
      </p>
    </div>
  </footer>
</BaseLayout>

<style>
  .site-header {
    background: #ffffff;
    border-bottom: 2px solid #e8e8e8;
    padding: 12px 0;
  }
  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .header-logo {
    height: 72px;
    width: auto;
    display: block;
  }
  .header-contact {
    text-align: right;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.7;
    color: #111;
  }
  .header-contact a {
    color: #111;
    text-decoration: none;
  }
  .header-contact div:last-child a {
    color: var(--color-accent-red);
  }
  @media (max-width: 640px) {
    .header-logo { height: 52px; }
    .header-contact { font-size: 0.75rem; }
  }
  .sales-page {
    background: var(--color-surface);
  }
  .site-footer {
    background: var(--color-primary);
    color: var(--color-bg);
    padding: var(--space-2xl) 0;
    text-align: center;
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }
  .footer-inner p {
    font-size: 0.85rem;
    color: #888;
    margin: var(--space-xs) 0;
  }
  .footer-inner a {
    color: #888;
    text-decoration: underline;
  }
  .footer-inner a:hover {
    color: var(--color-highlight);
  }
</style>
