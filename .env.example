# ============================================================
# FightScience Sale (sale.fightscience.com) — Environment Variables
# ============================================================
# Copy this file to `.env` and fill in real values.
# In production, set these in the Vercel project dashboard.
# `.env` is gitignored.
# ============================================================


# ─── Stripe ────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for local dev, live keys (sk_live_...) for prod.

STRIPE_SECRET_KEY=

# Webhook signing secret — verifies Stripe webhook authenticity.
# One-time setup in Stripe dashboard:
#   1. Developers → Webhooks → Add endpoint
#   2. URL: https://sale.fightscience.com/api/stripe-webhook
#   3. Event: checkout.session.completed
#   4. Copy signing secret (whsec_...) here
#
# For LOCAL dev, use the Stripe CLI:
#   stripe listen --forward-to localhost:4321/api/stripe-webhook
# The CLI outputs a temporary signing secret — use that locally.
#
# NEVER deploy without this — constructEvent() will throw and
# Stripe webhooks will fail.

STRIPE_WEBHOOK_SECRET=


# ─── Ontraport API ─────────────────────────────────────────
# Used for: contact creation, transaction logging (chargeLog),
# tag updates (Flash Sale Started / Purchased).
# Get from: https://app.ontraport.com → Administration → Integrations → Ontraport API

ONTRAPORT_API_KEY=
ONTRAPORT_APP_ID=


# ─── Ontraport Webhook Secret ──────────────────────────────
# This is the secret used when this app calls the fightscience.tv
# members-area webhook to grant course access after a purchase.
#
# CRITICAL: This MUST EXACTLY match the ONTRAPORT_WEBHOOK_SECRET
# env var in the members-area repo's Vercel project. If they drift,
# all course grants will fail silently (403 from members webhook).
#
# Where it's used:
#   - sale.fightscience.com (this app) — sends it in the POST body
#   - fightscience.tv (members-area) — verifies the received value
#
# Default: do not rotate. If you must rotate, update BOTH Vercel
# projects + all 10 Ontraport automation POST bodies in lockstep.

ONTRAPORT_WEBHOOK_SECRET=
